<%- include('partials/header') %>

<!-- About Hero -->
<section class="page-hero page-hero-about">
  <div class="container">
    <span class="section-label reveal-up">About Us</span>
    <h1 class="page-hero-title reveal-up delay-1">Our Story</h1>
    <p class="page-hero-subtitle reveal-up delay-2">
      <em>Mawingu</em> means <strong>clouds</strong> — symbolizing clarity, perspective, and elevation.
    </p>
  </div>
  <div class="page-hero-shape" aria-hidden="true">
    <svg viewBox="0 0 1440 200" preserveAspectRatio="none">
      <path d="M0,120 C200,180 400,60 600,100 C800,140 1000,40 1200,90 C1300,110 1400,80 1440,100 L1440,200 L0,200 Z" fill="var(--color-cloud)"/>
    </svg>
  </div>
</section>

<!-- Story Section -->
<section class="section section-story">
  <div class="container">
    <div class="story-grid">
      <div class="story-content">
        <h2 class="reveal-up">We exist to demystify HR.</h2>
        <p class="reveal-up delay-1">
          Founded three years ago, Mawingu formally launched operations in Kenya last year
          with renewed strategic focus and international leadership capacity.
        </p>
        <p class="reveal-up delay-2">
          Founders often believe HR is simple — until reality hits.
        </p>
      </div>

      <div class="story-pain-points">
        <div class="pain-card reveal-right delay-1">
          <div class="pain-number" aria-hidden="true">01</div>
          <p>Employee matters dominate leadership time</p>
        </div>
        <div class="pain-card reveal-right delay-2">
          <div class="pain-number" aria-hidden="true">02</div>
          <p>Growth outpaces structure</p>
        </div>
        <div class="pain-card reveal-right delay-3">
          <div class="pain-number" aria-hidden="true">03</div>
          <p>Compliance becomes a risk</p>
        </div>
        <div class="pain-card reveal-right delay-4">
          <div class="pain-number" aria-hidden="true">04</div>
          <p>Performance becomes inconsistent</p>
        </div>
      </div>
    </div>

    <div class="story-resolution reveal-up">
      <blockquote>
        We transition organizations from reactive HR to disciplined People governance.
      </blockquote>
    </div>
  </div>
</section>

<!-- Leadership Section -->
<section class="section section-leadership">
  <div class="container">
    <span class="section-label reveal-up">Leadership</span>
    <h2 class="section-title reveal-up delay-1">Meet the Founders</h2>

    <div class="leaders-grid">
      <!-- Sheila Kamaara -->
      <article class="leader-card reveal-up delay-2">
        <div class="leader-avatar">
          <div class="avatar-placeholder">
            <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
              <circle cx="60" cy="60" r="58" fill="var(--color-cloud)" stroke="var(--color-blue)" stroke-width="2"/>
              <circle cx="60" cy="45" r="18" fill="var(--color-blue)" opacity="0.2"/>
              <path d="M30 95 C30 72 90 72 90 95" fill="var(--color-blue)" opacity="0.15"/>
              <text x="60" y="65" text-anchor="middle" fill="var(--color-navy)" font-size="28" font-family="Playfair Display, serif" font-weight="600">SK</text>
            </svg>
          </div>
        </div>
        <div class="leader-info">
          <h3>Sheila Kamaara</h3>
          <p class="leader-role">Co-Founder | Lead, People & Culture Strategy</p>
          <p class="leader-bio">
            Strategic HR and People & Culture leader with over eight years of experience
            across consulting, sustainability, healthcare, and B-Corp environments.
          </p>
          <div class="leader-expertise">
            <h4>Core Expertise</h4>
            <ul>
              <li>HR strategy & workforce planning</li>
              <li>Performance management architecture</li>
              <li>Employee relations & compliance</li>
              <li>Payroll systems & compensation structuring</li>
              <li>Leadership development</li>
              <li>Organizational culture design</li>
            </ul>
          </div>
          <p class="leader-highlight">
            Track record of strengthening People systems in scaling teams of 150+ employees.
          </p>
        </div>
      </article>

      <!-- Sheila Saibala -->
      <article class="leader-card reveal-up delay-3">
        <div class="leader-avatar">
          <div class="avatar-placeholder">
            <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
              <circle cx="60" cy="60" r="58" fill="var(--color-cloud)" stroke="var(--color-gold)" stroke-width="2"/>
              <circle cx="60" cy="45" r="18" fill="var(--color-gold)" opacity="0.2"/>
              <path d="M30 95 C30 72 90 72 90 95" fill="var(--color-gold)" opacity="0.15"/>
              <text x="60" y="65" text-anchor="middle" fill="var(--color-navy)" font-size="28" font-family="Playfair Display, serif" font-weight="600">SS</text>
            </svg>
          </div>
        </div>
        <div class="leader-info">
          <h3>Sheila Saibala</h3>
          <p class="leader-role">Co-Founder | Governance & Risk Advisory</p>
          <p class="leader-bio">
            International transformation and governance specialist with enterprise-level
            experience in risk, compliance, and Agile environments.
          </p>
          <div class="leader-expertise">
            <h4>Core Expertise</h4>
            <ul>
              <li>Enterprise risk frameworks</li>
              <li>Incident & change management</li>
              <li>Governance systems</li>
              <li>Business continuity</li>
              <li>Structured reporting environments</li>
            </ul>
          </div>
          <p class="leader-highlight">
            Brings global governance discipline to African growth-stage businesses.
          </p>
        </div>
      </article>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="section section-cta">
  <div class="cta-bg-shapes" aria-hidden="true">
    <div class="blob blob-cta-1"></div>
    <div class="blob blob-cta-2"></div>
  </div>
  <div class="container">
    <div class="cta-content reveal-up">
      <h2>Ready to structure your growth?</h2>
      <p>Let's talk about building the People infrastructure your business needs.</p>
      <div class="cta-actions">
        <a href="https://wa.me/254717736303?text=Hello%20Mawingu%2C%20I'd%20like%20to%20discuss%20working%20together." class="btn btn-primary btn-lg" target="_blank" rel="noopener">
          <span>Start a Conversation</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
