<%- include('partials/header') %>

<!-- Contact Hero -->
<section class="page-hero page-hero-contact">
  <div class="container">
    <span class="section-label reveal-up">Get In Touch</span>
    <h1 class="page-hero-title reveal-up delay-1">Let's Talk</h1>
    <p class="page-hero-subtitle reveal-up delay-2">
      Whether you're scaling a team or repositioning your career — we're here.
    </p>
  </div>
  <div class="page-hero-shape" aria-hidden="true">
    <svg viewBox="0 0 1440 200" preserveAspectRatio="none">
      <path d="M0,120 C200,180 400,60 600,100 C800,140 1000,40 1200,90 C1300,110 1400,80 1440,100 L1440,200 L0,200 Z" fill="var(--color-cloud)"/>
