<!-- CTA -->
<section class="section section-cta">
  <div class="cta-bg-shapes" aria-hidden="true">
    <div class="blob blob-cta-1"></div>
    <div class="blob blob-cta-2"></div>
  </div>
  <div class="container">
    <div class="cta-content reveal-up">
      <h2>Let's Build Structured Growth.</h2>
      <p>The conversation starts here. Reach out and let's discuss what your business or career needs.</p>
      <div class="cta-actions">
        <a href="https://wa.me/254717736303?text=Hello%20Mawingu%2C%20I'd%20like%20to%20book%20a%20consultation." class="btn btn-primary btn-lg" target="_blank" rel="noopener">
