    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
    <div class="cloud-drift cloud-drift-1">
      <svg viewBox="0 0 200 80" xmlns="http://www.w3.org/2000/svg">
        <ellipse cx="100" cy="50" rx="80" ry="30" fill="rgba(46,123,213,0.06)"/>
        <ellipse cx="70" cy="45" rx="50" ry="22" fill="rgba(46,123,213,0.04)"/>
