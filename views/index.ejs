        <ellipse cx="60" cy="38" rx="45" ry="18" fill="rgba(27,63,107,0.03)"/>
      </svg>
    </div>
  </div>

  <div class="container hero-content">
    <div class="hero-text">
      <div class="hero-badge reveal-up">People Strategy Advisory</div>
      <h1 class="hero-title">
        <span class="reveal-up delay-1">Clarity in People.</span>
        <span class="reveal-up delay-2 text-accent">Structure in Growth.</span>
      </h1>
      <p class="hero-description reveal-up delay-3">
        Mawingu HR Solutions partners with growth-stage businesses and ambitious
        professionals to build structured, scalable People systems that drive performance.
      </p>
      <div class="hero-actions reveal-up delay-4">
        <a href="https://wa.me/254717736303?text=Hello%20Mawingu%2C%20I'd%20like%20to%20discuss%20HR%20advisory%20services." class="btn btn-primary" target="_blank" rel="noopener">
