<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Mawingu HR Solutions partners with growth-stage businesses and ambitious professionals to build structured, scalable People systems that drive performance.">
  <meta name="keywords" content="HR Solutions Kenya, People Strategy, HR Advisory, Career Coaching, Recruitment Kenya">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="page-<%= page %>">

  <!-- Grain overlay for organic texture -->
  <div class="grain-overlay" aria-hidden="true"></div>

  <!-- Navigation -->
  <nav class="main-nav" id="mainNav">
    <div class="nav-container">
      <a href="/" class="nav-logo" aria-label="Mawingu HR Solutions Home">
        <img class="logo-img" src="/images/mawingu-logo.png" alt="Mawingu HR Solutions Logo">
        <span class="logo-text">MAWINGU</span>
      </a>

      <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation" aria-expanded="false">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>

      <ul class="nav-links" id="navLinks">
        <li><a href="/" class="<%= page === 'home' ? 'active' : '' %>">Home</a></li>
        <li><a href="/about" class="<%= page === 'about' ? 'active' : '' %>">About</a></li>
        <li class="nav-dropdown">
          <a href="/corporate-services" class="<%= page === 'corporate' ? 'active' : '' %>">Corporate</a>
        </li>
        <li><a href="/professional-services" class="<%= page === 'professional' ? 'active' : '' %>">Professionals</a></li>
        <li><a href="/contact" class="nav-cta">Get In Touch</a></li>
      </ul>
    </div>
  </nav>
